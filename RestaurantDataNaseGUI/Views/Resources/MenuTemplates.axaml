<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="using:RestaurantDataNaseGUI.ViewModels"
                    xmlns:dtos="using:RestaurantDataNaseGUI.Models.DTOs"
                    xmlns:conv="using:Avalonia.Data.Converters"
                    xmlns:convLocal="using:RestaurantDataNaseGUI.Converters">

    <!--
        Template-uri comune pentru afisarea meniului, folosite atat in
        MenuView cat si in SearchView. x:CompileBindings="False" e necesar
        aici: fiecare View consumator are un DataContext de alt tip
        (MenuViewModel / SearchViewModel), asa ca legatura catre
        DataContext-ul UserControl-ului gazda nu poate fi validata static la
        compilare pentru ambele - foloseste bindare clasica (prin reflectie).

        Folosim $parent[UserControl].DataContext, NU ElementName=Root: acest
        fisier e un ResourceDictionary separat, importat prin ResourceInclude,
        iar in Avalonia ElementName se rezolva doar prin NameScope-ul propriu
        fisierului XAML curent - nu traverseaza granita catre NameScope-ul
        View-ului care il consuma (spre deosebire de $parent[T], care
        parcurge arborele vizual live, independent de NameScope/fisier).
        Vezi https://github.com/AvaloniaUI/Avalonia/issues/1572.

        Ambele ViewModel-uri expun o proprietate PoateComanda si o comanda
        AdaugaInCosCommand cu acelasi nume/semnatura, exact ca aceste
        binding-uri sa functioneze indiferent de View.
    -->

    <DataTemplate x:Key="MeniuAfisareItemTemplate" x:CompileBindings="False" x:DataType="dtos:MeniuAfisareDto">
        <Border Width="220" Margin="6" Padding="10" CornerRadius="6"
                BorderBrush="#33808080" BorderThickness="1">
            <StackPanel Spacing="6">
                <Grid Height="100">
                    <Image Source="{Binding PrimaImaginePath, Converter={x:Static convLocal:CaleImagineToBitmapConverter.Instance}}"
                           IsVisible="{Binding PrimaImaginePath, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"
                           Stretch="UniformToFill"/>
                    <Border Background="#22808080"
                            CornerRadius="4"
                            IsVisible="{Binding PrimaImaginePath, Converter={x:Static conv:StringConverters.IsNullOrEmpty}}">
                        <TextBlock Text="Fara imagine"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.6"
                                   FontSize="11"/>
                    </Border>
                </Grid>

                <TextBlock Text="{Binding Denumire}" FontWeight="SemiBold" TextWrapping="Wrap"/>

                <TextBlock Text="Meniu compus"
                           IsVisible="{Binding EsteMeniuCompus}"
                           FontStyle="Italic" FontSize="11" Opacity="0.7"/>

                <TextBlock Text="{Binding Pret, StringFormat='{}{0:0.00} lei'}"/>

                <TextBlock Text="{Binding CantitateText}"
                           IsVisible="{Binding CantitateText, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}"
                           FontSize="12" Opacity="0.8"/>

                <TextBlock Text="{Binding AlergeniText}"
                           FontSize="11" TextWrapping="Wrap" Opacity="0.7"/>

                <TextBlock Text="Indisponibil"
                           IsVisible="{Binding EsteIndisponibil}"
                           Foreground="Red" FontWeight="Bold" FontSize="12"/>

                <Button Content="Comanda"
                        Command="{Binding $parent[UserControl].DataContext.AdaugaInCosCommand}"
                        CommandParameter="{Binding}"
                        IsVisible="{Binding $parent[UserControl].DataContext.PoateComanda}"
                        IsEnabled="{Binding !EsteIndisponibil}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="CategorieGrupataTemplate" x:CompileBindings="False" x:DataType="vm:CategorieGrupataViewModel">
        <StackPanel Margin="16,8" Spacing="8">
            <TextBlock Text="{Binding Denumire}" FontSize="18" FontWeight="SemiBold"/>

            <ItemsControl ItemsSource="{Binding Itemi}"
                          ItemTemplate="{StaticResource MeniuAfisareItemTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
