# Copiaza acest fisier in ".env" (in acelasi folder, docker/) si completeaza
# parola inainte de a porni containerul:
#   cp docker/.env.example docker/.env
#
# Fisierul .env NU trebuie comis in git (e deja in .gitignore).

# Parola contului "sa" (System Administrator) al SQL Server.
# SQL Server refuza sa porneasca daca parola nu respecta cerintele de
# complexitate:
#   - minim 8 caractere
#   - contine caractere din cel putin 3 din urmatoarele 4 categorii:
#       * litere mari (A-Z)
#       * litere mici (a-z)
#       * cifre (0-9)
#       * simboluri (!@#$%^&*()_+-=...)
#   - nu poate fi o parola comuna/slaba (ex. "Password1" e respinsa)
MSSQL_SA_PASSWORD=SchimbaAceastaParola123!

# Parola userului dedicat aplicatiei ("marius"), creat de
# docker/create-app-user.sql - aplicatia se conecteaza cu acest user, nu cu
# "sa" (vezi docker/README.md). Aceleasi cerinte de complexitate ca mai sus:
#   - minim 8 caractere
#   - caractere din cel putin 3 din urmatoarele 4 categorii: litere mari,
#     litere mici, cifre, simboluri
DB_USER_PASSWORD=SchimbaAceastaParola456!
