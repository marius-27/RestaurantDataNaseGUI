# Copiaza acest fisier in "secret.local.yaml" (acelasi folder, k8s/) si
# inlocuieste valorile din `data:` cu parolele tale reale, encodate base64:
#
#   cp k8s/secret.local.yaml.example k8s/secret.local.yaml
#
# Genereaza fiecare valoare asa (NU uita -n, altfel se adauga o linie noua
# in parola decodata, iar SQL Server o respinge la pornire):
#
#   echo -n 'ParolaTaSaReala123!' | base64
#   echo -n 'ParolaTaDbUserReala456!' | base64
#
# k8s/secret.local.yaml NU trebuie comis in git (e deja in .gitignore) -
# acelasi rol ca docker/.env pentru varianta Docker Compose: fiecare
# dezvoltator/masina isi seteaza propriile parole local.
#
# Cerintele SQL Server pentru ambele parole (altfel containerul refuza sa
# porneasca / CREATE LOGIN esueaza in k8s/init-job.yaml):
#   - minim 8 caractere
#   - caractere din cel putin 3 din urmatoarele 4 categorii: litere mari,
#     litere mici, cifre, simboluri
#   - nu poate fi o parola comuna/slaba
apiVersion: v1
kind: Secret
metadata:
  name: sqlserver-credentials
  namespace: restaurant-datanase
type: Opaque
data:
  MSSQL_SA_PASSWORD: <base64-ul parolei sa aici>
  DB_USER_PASSWORD: <base64-ul parolei userului "marius" aici>
